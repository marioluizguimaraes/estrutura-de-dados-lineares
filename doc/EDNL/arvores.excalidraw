    {
      "id": "NfICt6oVrulQidZ-aLbgq",
      "type": "text",
      "x": 2237.4582850626966,
      "y": 2535.23269509803,
      "width": 1408,
      "height": 1400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bEt",
      "roundness": null,
      "seed": 120292049,
      "version": 2754,
      "versionNonce": 274443935,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763306243647,
      "link": null,
      "locked": false,
      "text": "public NodeAVL rotation (NodeAVL node, NodeAVL nodeParent) {\n    if (nodeParent.fatorBalanceamento == -2 && node.fatorBalanceamento == -1) return this.simpleRightRotation(node, nodeParent);\n    if (nodeParent.fatorBalanceamento == -2 && node.fatorBalanceamento == 1) return this.doubleRightRotation(node, nodeParent);\n    if (nodeParent.fatorBalanceamento == 2 && node.fatorBalancemaneto == 1) return this.simpleLeftRotation(node, nodeParent);\n    if (nodeParent.fatorBalanceamento == 2 && node.fatorBalanceamento == -1) return this.doubleLeftRotation(node, nodeParent);\n}\n\nprivate NodeAVL simpleRightRotation (NodeAVL leftChild, NodeAVL parent) {\n    NodeAVL grandParent = parent.parent;\n\n    if (grandParent.leftChild == parent) grandParent.leftChild = leftChild;\n    if (grandeParent.rightChild == parent) grandParent.rightChild = leftChild;\n\n    NodeAVL subTree = leftChild.rightChild;\n\n    parent.parent = leftChild;\n    leftChild.rightChild = parent;\n    parent.leftChild = subTree;\n    if (subTree != null) subTree.parent = parent;\n    leftChild.parent = grandParent;\n    \n    parent.fatorBalanceamento = parent.fatorBalanceamento + 1 - Math.min(leftChild.fatorBalanceamento, 0);\n    leftChild.fatorBalanceamento = leftChild.fatorBalanceamento + 1 + Math.max(parent.fatorBalanceamento, 0);\n\n    return leftChild;\n}\n\nprivate NodeAVL simpleLeftRotation (NodeAVL rightChild, NodeAVL parent) {\n    NodeAVL grandParent = parent.parent;\n\n    if (grandParent.leftChild == parent) grandParent.leftChild = rightChild;\n    if (grandeParent.rightChild == parent) grandParent.rightChild = rightChild;\n\n    NodeAVL subTree = rightChild.leftChild;\n\n    parent.parent = rightChild;\n    rightChild.leftChild = parent;\n    parent.rightChild = subTree;\n    if (subTree != null) subTree.parent = parent;\n    rightChild.parent = grandParent;\n    \n    parent.fatorBalanceamento = parent.fatorBalanceamento - 1 - Math.max(rightChild.fatorBalanceamento, 0);\n    rightChild.fatorBalanceamento = rightChild.fatorBalanceamento - 1 + Math.min(parent.fatorBalanceamento, 0);\n\n    return rightChild;\n}\n\nprivate doubleRightRotation (NodeAVL leftChild, NodeAVL parent) {\n    this.simpleLeftRotation(leftChild.rightChild, leftChild);\n    return this.simpleRightRotation(parent.leftChild, parent);\n}\n\nprivate roubleLeftRotation (NodeAVL rightChild, NodeAVL parent) {\n    this.simpleRightRotation(rightChild.leftChild, rightChild);\n    return this.simpleLeftRotation(parent.rightChild, parent);\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public NodeAVL rotation (NodeAVL node, NodeAVL nodeParent) {\n    if (nodeParent.fatorBalanceamento == -2 && node.fatorBalanceamento == -1) return this.simpleRightRotation(node, nodeParent);\n    if (nodeParent.fatorBalanceamento == -2 && node.fatorBalanceamento == 1) return this.doubleRightRotation(node, nodeParent);\n    if (nodeParent.fatorBalanceamento == 2 && node.fatorBalancemaneto == 1) return this.simpleLeftRotation(node, nodeParent);\n    if (nodeParent.fatorBalanceamento == 2 && node.fatorBalanceamento == -1) return this.doubleLeftRotation(node, nodeParent);\n}\n\nprivate NodeAVL simpleRightRotation (NodeAVL leftChild, NodeAVL parent) {\n    NodeAVL grandParent = parent.parent;\n\n    if (grandParent.leftChild == parent) grandParent.leftChild = leftChild;\n    if (grandeParent.rightChild == parent) grandParent.rightChild = leftChild;\n\n    NodeAVL subTree = leftChild.rightChild;\n\n    parent.parent = leftChild;\n    leftChild.rightChild = parent;\n    parent.leftChild = subTree;\n    if (subTree != null) subTree.parent = parent;\n    leftChild.parent = grandParent;\n    \n    parent.fatorBalanceamento = parent.fatorBalanceamento + 1 - Math.min(leftChild.fatorBalanceamento, 0);\n    leftChild.fatorBalanceamento = leftChild.fatorBalanceamento + 1 + Math.max(parent.fatorBalanceamento, 0);\n\n    return leftChild;\n}\n\nprivate NodeAVL simpleLeftRotation (NodeAVL rightChild, NodeAVL parent) {\n    NodeAVL grandParent = parent.parent;\n\n    if (grandParent.leftChild == parent) grandParent.leftChild = rightChild;\n    if (grandeParent.rightChild == parent) grandParent.rightChild = rightChild;\n\n    NodeAVL subTree = rightChild.leftChild;\n\n    parent.parent = rightChild;\n    rightChild.leftChild = parent;\n    parent.rightChild = subTree;\n    if (subTree != null) subTree.parent = parent;\n    rightChild.parent = grandParent;\n    \n    parent.fatorBalanceamento = parent.fatorBalanceamento - 1 - Math.max(rightChild.fatorBalanceamento, 0);\n    rightChild.fatorBalanceamento = rightChild.fatorBalanceamento - 1 + Math.min(parent.fatorBalanceamento, 0);\n\n    return rightChild;\n}\n\nprivate doubleRightRotation (NodeAVL leftChild, NodeAVL parent) {\n    this.simpleLeftRotation(leftChild.rightChild, leftChild);\n    return this.simpleRightRotation(parent.leftChild, parent);\n}\n\nprivate roubleLeftRotation (NodeAVL rightChild, NodeAVL parent) {\n    this.simpleRightRotation(rightChild.leftChild, rightChild);\n    return this.simpleLeftRotation(parent.rightChild, parent);\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
