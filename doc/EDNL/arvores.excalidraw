    {
      "id": "Xq3PHyJB7yuyW8EcHfC4D",
      "type": "text",
      "x": 1633.5352651317103,
      "y": 484.3465954848953,
      "width": 1188,
      "height": 475,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0D",
      "roundness": null,
      "seed": 1933476095,
      "version": 1108,
      "versionNonce": 232069705,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763305975937,
      "link": null,
      "locked": false,
      "text": "\npublic NodeAVL search(int value){\n    \n    NodeAVL node = treeSearch(getRoot(), value);\n    \n    if ( node.value == value ) return node;\n\n    return null\n\n}\n\n\npublic NodeAVL treeSearch (NodeAvl actual, int value) {\n    if (actual.value > value && actual.leftChild != null) return this.treeSearch(actual.leftChild, value);\n    if (actual.value < value && actual.rightChild != null) return this.treeSearch(actual.rightChild, value);\n\n    // Não é nem maior nem menor (é igual) ou não tem nenhum filho\n    return actual;\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\npublic NodeAVL search(int value){\n    \n    NodeAVL node = treeSearch(getRoot(), value);\n    \n    if ( node.value == value ) return node;\n\n    return null\n\n}\n\n\npublic NodeAVL treeSearch (NodeAvl actual, int value) {\n    if (actual.value > value && actual.leftChild != null) return this.treeSearch(actual.leftChild, value);\n    if (actual.value < value && actual.rightChild != null) return this.treeSearch(actual.rightChild, value);\n\n    // Não é nem maior nem menor (é igual) ou não tem nenhum filho\n    return actual;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
