    {
      "id": "W1gPHjgA6GGkV-DRlxi1G",
      "type": "text",
      "x": 6279.735609827371,
      "y": 2370.2199710926934,
      "width": 1199,
      "height": 700,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5W",
      "roundness": null,
      "seed": 1704878175,
      "version": 941,
      "versionNonce": 1180851783,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763305882455,
      "link": null,
      "locked": false,
      "text": "public int remove (int value) {\n    NodeAVL actual = this.treeSearch(value);\n\n    this.ajustaFatorBalanceamentoRemocao(actual);\n\n    return this.removeNode(actual);\n}\n\nprivate int removeNode(NodeAVL actual) {\n    NodeAVL parent = actual.parent;\n    actual.parent = null;    \n\n    if (node == parent.leftChild) parent.leftChild = null;\n    if (node == parent.rightChild) parent.rightChild = null;\n}\n\nprivate void ajustaFatorBalanceamentoRemocao (NodeAVL actual) {\n    NodeAVL parent = new.parent;\n\n    if (actual == parent.leftChild) parent.fatorBalanceamento = parent.fatorBalanceamento + 1;\n    if (actual == parent.rightChild) parent.fatorBalanceamento = parent.fatorBalanceamento - 1;\n\n    if (parent.fatorBalanceamento == 2 || parent.fatorBalanceamento == -2) parent = this.rotate(parent, new);\n\n    if (parent.fatorBalanceamento != 0 || parent == this.root) return;\n\n    this.ajustaFatorBalanceamentoRemocao(parent);\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public int remove (int value) {\n    NodeAVL actual = this.treeSearch(value);\n\n    this.ajustaFatorBalanceamentoRemocao(actual);\n\n    return this.removeNode(actual);\n}\n\nprivate int removeNode(NodeAVL actual) {\n    NodeAVL parent = actual.parent;\n    actual.parent = null;    \n\n    if (node == parent.leftChild) parent.leftChild = null;\n    if (node == parent.rightChild) parent.rightChild = null;\n}\n\nprivate void ajustaFatorBalanceamentoRemocao (NodeAVL actual) {\n    NodeAVL parent = new.parent;\n\n    if (actual == parent.leftChild) parent.fatorBalanceamento = parent.fatorBalanceamento + 1;\n    if (actual == parent.rightChild) parent.fatorBalanceamento = parent.fatorBalanceamento - 1;\n\n    if (parent.fatorBalanceamento == 2 || parent.fatorBalanceamento == -2) parent = this.rotate(parent, new);\n\n    if (parent.fatorBalanceamento != 0 || parent == this.root) return;\n\n    this.ajustaFatorBalanceamentoRemocao(parent);\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
