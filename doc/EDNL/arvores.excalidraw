    {
      "id": "4YNNV83NC6zlVCIzjAyOJ",
      "type": "text",
      "x": 6534.629372250226,
      "y": 442.66851772727205,
      "width": 539,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3Y",
      "roundness": null,
      "seed": 1955586111,
      "version": 509,
      "versionNonce": 1581523079,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763300562730,
      "link": null,
      "locked": false,
      "text": "public NodeAVL insert (int value) {\n    NodeAVL parent = this.treeSearch(value);\n\n    NodeAVL new = this.createNode(parent, value);\n\n    this.ajusteFatorBalanceamentoInsercao(new);\n\n    return new;\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public NodeAVL insert (int value) {\n    NodeAVL parent = this.treeSearch(value);\n\n    NodeAVL new = this.createNode(parent, value);\n\n    this.ajusteFatorBalanceamentoInsercao(new);\n\n    return new;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xRZ9CSq8VBc3KkGA-gd-F",
      "type": "text",
      "x": 6531.097986968839,
      "y": 702.875227683982,
      "width": 605,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3Z",
      "roundness": null,
      "seed": 760592977,
      "version": 416,
      "versionNonce": 2115794855,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763300562730,
      "link": null,
      "locked": false,
      "text": "private NodeAVL createNode(NodeAVL parent, int value) {\n    NodeAVL new = new NodeAVL(int value);\n    new.fatorBalanceamento = 0;\n    new.parent = parent;\n\n    if (value < parent.value) parent.leftChild = new;\n    if (value > parent.value) parent.rightChild = new;\n\n    return new;\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "private NodeAVL createNode(NodeAVL parent, int value) {\n    NodeAVL new = new NodeAVL(int value);\n    new.fatorBalanceamento = 0;\n    new.parent = parent;\n\n    if (value < parent.value) parent.leftChild = new;\n    if (value > parent.value) parent.rightChild = new;\n\n    return new;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "i64KcfRvkmNohi3-NC0hy",
      "type": "text",
      "x": 6533.097986968839,
      "y": 1025.8752276839818,
      "width": 1012,
      "height": 375,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3a",
      "roundness": null,
      "seed": 1649664319,
      "version": 767,
      "versionNonce": 723315399,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763300562730,
      "link": null,
      "locked": false,
      "text": "private void ajusteFatorBalanceamentoInsercao(NodeAVL new) {\n    NodeAVL parent = new.parent;\n\n    if (new == parent.leftChild) parent.fatorBalanceamento = parent.fatorBalanceamento - 1;\n    if (new == parent.rightChild) parent.fatorBalanceamento = parent.fatorBalanceamento + 1;\n\n    if (parent.fatorBalanceamento == 2 || parent.fatorBalanceamento == -2) {\n        this.rotate(parent, new);\n        return;\n    }\n\n    if (parent.fatorBalanceamento == 0 || parent == this.root) return;\n\n    this.ajusteFatorBalanceamentoInsercao(parent);\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "private void ajusteFatorBalanceamentoInsercao(NodeAVL new) {\n    NodeAVL parent = new.parent;\n\n    if (new == parent.leftChild) parent.fatorBalanceamento = parent.fatorBalanceamento - 1;\n    if (new == parent.rightChild) parent.fatorBalanceamento = parent.fatorBalanceamento + 1;\n\n    if (parent.fatorBalanceamento == 2 || parent.fatorBalanceamento == -2) {\n        this.rotate(parent, new);\n        return;\n    }\n\n    if (parent.fatorBalanceamento == 0 || parent == this.root) return;\n\n    this.ajusteFatorBalanceamentoInsercao(parent);\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "8kDLEYNT8sGbzJQ-Krj80",
