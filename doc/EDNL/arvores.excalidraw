      "text": "public NodeRN insetion (int value) {\n    NodeRN parent = this.treeSearch(value);\n\n    NodeRN new = this.createNode(parent, value);\n\n    if (parent.cor == vermelho) this.rebalance(new, parent);\n\n    return new;\n}\n\nprivate NodeRN createNode (NodeRN parent, int value) {\n    NodeRN newNode = new NodeRN(value);\n    if (this.isEmpty) {\n        newNode.cor = preto;\n        this.root = newNode;\n    }\n    if (!this.isEmpty) newNode.cor = vermelho;\n    newNode.parent = parent;\n    \n    if (parent.value > value) parent.leftChild = newNode;\n    if (parent.value < value) parent.rightChild = newNode;\n\n    return newNode;\n}\n\nprivate void rebalance (NodeRN new, NodeRN parent) {\n    NodeAVL grandParent = parent.parent;\n    \n    NodeRN uncle;\n    if (grandParent.leftChild == parent) uncle = grandParent.rightChild;\n    if (grandParent.rightChild == parent) uncle = grandParent.leftChild;\n\n    if (uncle.cor == vermelho) this.repintation(parent, uncle, grandParent);\n    if (uncle.cor == preto) this.rotation(actual, parent, uncle, grandParent);\n}\n\nprivate void repitation (NodeRN actual, NodeRN parent, NodeRN uncle, NodeRN grandParent) {\n    parent.cor = preto;\n    uncle.cor = preto;\n    if (grandParent != this.root) grandParent.cor = vermelho;\n}\n\nprivate void rotation (NodeRN parent, NodeRN uncle, NodeRN grandParent) {\n    if (grandParent.leftChild == parent && parent.leftChild == actual) {\n        this.simpleRightRotation(uncle, grandParent);\n        actual.cor = vermelho\n        parent.cor = preto;\n    }\n\n    if (grandParent.leftChild == parent && parent.rightChild == actual) {\n        this.doubleRightRotation(uncle, grandParent);\n        actual.cor = preto;\n        parent.cor = vermelho;\n    }\n\n    if (grandParent.rightChild == parent && parent.rightChild == actual) {\n        this.simpleLeftRotation(uncle, grandParent);\n        actual.cor = vermelho;\n        parent.cor = preto;\n    } \n\n    if (grandParent.rightChild == parent && parent.leftChild == actual) {\n        this.doubleLeftRotation(uncle, grandParent);\n        actual.cor = preto;\n        parent.cor = vermelho;\n    } \n\n    grandParent.cor = vermelho;\n    uncle.cor = preto;\n}\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public NodeRN insetion (int value) {\n    NodeRN parent = this.treeSearch(value);\n\n    NodeRN new = this.createNode(parent, value);\n\n    if (parent.cor == vermelho) this.rebalance(new, parent);\n\n    return new;\n}\n\nprivate NodeRN createNode (NodeRN parent, int value) {\n    NodeRN newNode = new NodeRN(value);\n    if (this.isEmpty) {\n        newNode.cor = preto;\n        this.root = newNode;\n    }\n    if (!this.isEmpty) newNode.cor = vermelho;\n    newNode.parent = parent;\n    \n    if (parent.value > value) parent.leftChild = newNode;\n    if (parent.value < value) parent.rightChild = newNode;\n\n    return newNode;\n}\n\nprivate void rebalance (NodeRN new, NodeRN parent) {\n    NodeAVL grandParent = parent.parent;\n    \n    NodeRN uncle;\n    if (grandParent.leftChild == parent) uncle = grandParent.rightChild;\n    if (grandParent.rightChild == parent) uncle = grandParent.leftChild;\n\n    if (uncle.cor == vermelho) this.repintation(parent, uncle, grandParent);\n    if (uncle.cor == preto) this.rotation(actual, parent, uncle, grandParent);\n}\n\nprivate void repitation (NodeRN actual, NodeRN parent, NodeRN uncle, NodeRN grandParent) {\n    parent.cor = preto;\n    uncle.cor = preto;\n    if (grandParent != this.root) grandParent.cor = vermelho;\n}\n\nprivate void rotation (NodeRN parent, NodeRN uncle, NodeRN grandParent) {\n    if (grandParent.leftChild == parent && parent.leftChild == actual) {\n        this.simpleRightRotation(uncle, grandParent);\n        actual.cor = vermelho\n        parent.cor = preto;\n    }\n\n    if (grandParent.leftChild == parent && parent.rightChild == actual) {\n        this.doubleRightRotation(uncle, grandParent);\n        actual.cor = preto;\n        parent.cor = vermelho;\n    }\n\n    if (grandParent.rightChild == parent && parent.rightChild == actual) {\n        this.simpleLeftRotation(uncle, grandParent);\n        actual.cor = vermelho;\n        parent.cor = preto;\n    } \n\n    if (grandParent.rightChild == parent && parent.leftChild == actual) {\n        this.doubleLeftRotation(uncle, grandParent);\n        actual.cor = preto;\n        parent.cor = vermelho;\n    } \n\n    grandParent.cor = vermelho;\n    uncle.cor = preto;\n}\n\n",
