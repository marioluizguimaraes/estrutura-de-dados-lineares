    {
      "id": "SHZfhD9InpI7zPOorEeK-",
      "type": "text",
      "x": 10101.950501229629,
      "y": 7424.04600984478,
      "width": 1006.9818115234375,
      "height": 825,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bUb",
      "roundness": null,
      "seed": 218652999,
      "version": 51,
      "versionNonce": 1534394343,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763337106301,
      "link": null,
      "locked": false,
      "text": "private void brotherRed (NodeRN brother, NodeRN parent) {\n    if (parent.leftChild = brother) this.simpleRightRotation(parent, brother);\n    if (parent.rightChild = brother) this.simpleLeftRotation(parent, brother);\n\n    brother.cor = preto;\n    parent.cor = vermelho;\n}\n\nprivate void SobrinhoLongeRed (NodeRN brother, NodeRN parent, NodeRN sobrinhoLonge) {\n    if (parent.leftChild = brother) this.simpleRightRotation(parent, brother);\n    if (parent.rightChild = brother) this.simpleLeftRotation(parent, brother);\n\n    brother.cor = parent.cor;\n    parent.cor = preto;\n    sobrinhoLonge.cor = preto;\n}\n\nprivate void sobrinhoPertoRed (NodeRN sobrinhoPerto, NodeRN brother) {\n    if (brother.leftChild = sobrinhoPerto) this.simpleRightRotation(sobrinhoPerto, brother);\n    if (brother.rightChild = sobrinhoPerto) this.simpleLeftRotation(sobrinhoPerto, brother);\n\n    brother.cor = vermelho;\n    sorbinhoPerto.cor = preto;\n}\n\nprivate void parentRed (NodeRN brother, NodeRN parent) {\n    parent.cor = preto;\n    brother.cor = vermelho;\n}\n\nprivate void allBlack (NodeRN brother) {\n    brother.cor = vermelho;\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "private void brotherRed (NodeRN brother, NodeRN parent) {\n    if (parent.leftChild = brother) this.simpleRightRotation(parent, brother);\n    if (parent.rightChild = brother) this.simpleLeftRotation(parent, brother);\n\n    brother.cor = preto;\n    parent.cor = vermelho;\n}\n\nprivate void SobrinhoLongeRed (NodeRN brother, NodeRN parent, NodeRN sobrinhoLonge) {\n    if (parent.leftChild = brother) this.simpleRightRotation(parent, brother);\n    if (parent.rightChild = brother) this.simpleLeftRotation(parent, brother);\n\n    brother.cor = parent.cor;\n    parent.cor = preto;\n    sobrinhoLonge.cor = preto;\n}\n\nprivate void sobrinhoPertoRed (NodeRN sobrinhoPerto, NodeRN brother) {\n    if (brother.leftChild = sobrinhoPerto) this.simpleRightRotation(sobrinhoPerto, brother);\n    if (brother.rightChild = sobrinhoPerto) this.simpleLeftRotation(sobrinhoPerto, brother);\n\n    brother.cor = vermelho;\n    sorbinhoPerto.cor = preto;\n}\n\nprivate void parentRed (NodeRN brother, NodeRN parent) {\n    parent.cor = preto;\n    brother.cor = vermelho;\n}\n\nprivate void allBlack (NodeRN brother) {\n    brother.cor = vermelho;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
