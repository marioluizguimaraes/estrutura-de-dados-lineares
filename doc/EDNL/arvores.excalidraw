    {
      "id": "mF0QuBeZKq8rqqNran6SG",
      "type": "text",
      "x": 8896.121462978064,
      "y": 7421.89399066971,
      "width": 990.1311300737727,
      "height": 2425,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bTxG",
      "roundness": null,
      "seed": 1275683079,
      "version": 4110,
      "versionNonce": 580694183,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763337106301,
      "link": null,
      "locked": false,
      "text": "public int remove (int value) {\n    NodeRN actual = this.treeSeach(value);\n\n    NodeRN sucessor = this.findSucessor(actual);\n\n    if (sucessor.cor == preto) this.rebalance(sucessor);\n\n    return this.removeNode(actual, sucessor);\n}\n\nprivate int removeNode (NodeRN actual, NodeRN sucessor) {\n    int value = actual.value;\n    actual.value = sucessor.value;\n    \n    NodeRN parent = sucessor.parent;\n    if (sucessor == parent.leftChild) parent.leftChild = null;\n    if (sucessor == parent.rightChild) parent.rightChild = null;\n\n    sucessor.parent = null;\n    return value;\n}\n \nprivate NodeRN findSucessor (NodeRN actual) {\n    NodeRN sucessor;\n    if (actual.rightChild != null) sucessor = actual.rightChild;\n    if (actual.rightChild == null) sucessor = actual.leftChild;\n    if (actual.leftChild == null && actual.rightChild == null) sucessor = actual;\n\n    while (sucessor.leftChild != null) sucessor = sucessor.leftChild;\n\n    return sucessor;\n}\n\nprivate void rebalance(NodeRN actual) {\n    NodeRN parent = actual.parent;\n\n    NodeRN brother;\n    if (parent.leftChild == actual) brother = parent.rightChild;\n    if (parent.rightChild == actual) brother = parent.leftChild;\n\n    NodeRN sobrinhoPerto;\n    NodeRN sobrinho Longe;\n    if (parent.leftChild == brother) {\n        sobrinhoPerto = brother.rightChild;\n        sobrinhoLonge = brother.leftChild;\n    }\n\n    if (parent.rightChild == brother) {\n        sobrinhoPerto = brother.leftChild;\n        sobrinhoLonge = brother.rightChild;\n    }\n\n    if (brother.cor = vermelho) {\n        this.brotherRed(brother, parent);\n        \n        if (parent.leftChild == actual) brother = parent.rightChild;\n        if (parent.rightChild == actual) brother = parent.leftChild;\n\n        if (parent.leftChild == brother) {\n            sobrinhoPerto = brother.rightChild;\n            sobrinhoLonge = brother.leftChild;\n        }\n    \n        if (parent.rightChild == brother) {\n            sobrinhoPerto = brother.leftChild;\n            sobrinhoLonge = brother.rightChild;\n        }\n    }\n\n    if (sobrinhoLonge.cor = vermelho) {\n        this.sobrinhoLongeRed(brother, parent, sobrinhoLonge);\n        return;\n    }\n\n    if (sorbinhoPerto.cor = vermelho) {\n        this.sobrinhoPertoRed(sobrinhoPerto, brother);\n        \n        if (parent.leftChild == actual) brother = parent.rightChild;\n        if (parent.rightChild == actual) brother = parent.leftChild;\n\n        if (parent.leftChild == brother) sobrinhoLonge = brother.leftChild;\n        if (parent.rightChild == brother) sobrinhoLonge = brother.rightChild;\n        \n        this.sobrinhoLongeRed(brother, parent, sobrinhoLonge);\n        return;\n    }\n\n    if (parent.cor = vermelho) {\n        this.parentRed(brother, parent);\n        return; \n    }\n\n    this.allBlack(brother);\n    this.rebalance(parent);\n}\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public int remove (int value) {\n    NodeRN actual = this.treeSeach(value);\n\n    NodeRN sucessor = this.findSucessor(actual);\n\n    if (sucessor.cor == preto) this.rebalance(sucessor);\n\n    return this.removeNode(actual, sucessor);\n}\n\nprivate int removeNode (NodeRN actual, NodeRN sucessor) {\n    int value = actual.value;\n    actual.value = sucessor.value;\n    \n    NodeRN parent = sucessor.parent;\n    if (sucessor == parent.leftChild) parent.leftChild = null;\n    if (sucessor == parent.rightChild) parent.rightChild = null;\n\n    sucessor.parent = null;\n    return value;\n}\n \nprivate NodeRN findSucessor (NodeRN actual) {\n    NodeRN sucessor;\n    if (actual.rightChild != null) sucessor = actual.rightChild;\n    if (actual.rightChild == null) sucessor = actual.leftChild;\n    if (actual.leftChild == null && actual.rightChild == null) sucessor = actual;\n\n    while (sucessor.leftChild != null) sucessor = sucessor.leftChild;\n\n    return sucessor;\n}\n\nprivate void rebalance(NodeRN actual) {\n    NodeRN parent = actual.parent;\n\n    NodeRN brother;\n    if (parent.leftChild == actual) brother = parent.rightChild;\n    if (parent.rightChild == actual) brother = parent.leftChild;\n\n    NodeRN sobrinhoPerto;\n    NodeRN sobrinho Longe;\n    if (parent.leftChild == brother) {\n        sobrinhoPerto = brother.rightChild;\n        sobrinhoLonge = brother.leftChild;\n    }\n\n    if (parent.rightChild == brother) {\n        sobrinhoPerto = brother.leftChild;\n        sobrinhoLonge = brother.rightChild;\n    }\n\n    if (brother.cor = vermelho) {\n        this.brotherRed(brother, parent);\n        \n        if (parent.leftChild == actual) brother = parent.rightChild;\n        if (parent.rightChild == actual) brother = parent.leftChild;\n\n        if (parent.leftChild == brother) {\n            sobrinhoPerto = brother.rightChild;\n            sobrinhoLonge = brother.leftChild;\n        }\n    \n        if (parent.rightChild == brother) {\n            sobrinhoPerto = brother.leftChild;\n            sobrinhoLonge = brother.rightChild;\n        }\n    }\n\n    if (sobrinhoLonge.cor = vermelho) {\n        this.sobrinhoLongeRed(brother, parent, sobrinhoLonge);\n        return;\n    }\n\n    if (sorbinhoPerto.cor = vermelho) {\n        this.sobrinhoPertoRed(sobrinhoPerto, brother);\n        \n        if (parent.leftChild == actual) brother = parent.rightChild;\n        if (parent.rightChild == actual) brother = parent.leftChild;\n\n        if (parent.leftChild == brother) sobrinhoLonge = brother.leftChild;\n        if (parent.rightChild == brother) sobrinhoLonge = brother.rightChild;\n        \n        this.sobrinhoLongeRed(brother, parent, sobrinhoLonge);\n        return;\n    }\n\n    if (parent.cor = vermelho) {\n        this.parentRed(brother, parent);\n        return; \n    }\n\n    this.allBlack(brother);\n    this.rebalance(parent);\n}\n\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
